    {
      "parameters": {
        "jsCode": "const lead = $('Set — Map Fields').first().json;\nconst groqRaw = $input.first().json?.choices?.[0]?.message?.content ?? '{}';\nconst cleaned = groqRaw.replace(/```json\\s*/gi,'').replace(/```\\s*/gi,'').trim();\n\nlet ai;\ntry { ai = JSON.parse(cleaned); }\ncatch(e) {\n  ai = { score:'Warm', priority:5, reason:'Parse error', buying_intent:'Medium', suggested_approach:'Send a friendly intro email.', email_subject:'Following up on your enquiry' };\n}\n\nreturn [{\n  json: {\n    ...lead,\n    lead_score:          ai.score,\n    lead_priority:       ai.priority,\n    lead_reason:         ai.reason,\n    buying_intent:       ai.buying_intent,\n    suggested_approach:  ai.suggested_approach,\n    email_subject:       ai.email_subject\n  }\n}];"
      },
