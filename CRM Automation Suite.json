        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.3-70b-versatile\",\n  \"temperature\": 0.2,\n  \"max_tokens\": 400,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert sales lead qualification AI. Analyze the lead and return ONLY a raw JSON object — no markdown, no backticks, no explanation. Respond with exactly this format:\\n{\\n  \\\"score\\\": \\\"Hot\\\" or \\\"Warm\\\" or \\\"Cold\\\",\\n  \\\"priority\\\": a number 1-10,\\n  \\\"reason\\\": \\\"One sentence why\\\",\\n  \\\"buying_intent\\\": \\\"High\\\" or \\\"Medium\\\" or \\\"Low\\\",\\n  \\\"suggested_approach\\\": \\\"One sentence on how to approach this lead\\\",\\n  \\\"email_subject\\\": \\\"A compelling subject line for the first email\\\"\\n}\\n\\nHot = strong buying intent, specific need, decision maker. Warm = interested but vague. Cold = just browsing.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Lead info:\\nName: {{ $json.name }}\\nCompany: {{ $json.company }}\\nEmail: {{ $json.email }}\\nPhone: {{ $json.phone }}\\nMessage: {{ $json.message }}\\nSource: {{ $json.source }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "id": "c17df7cd-bae4-4d39-ae13-9b3056410ea1",
